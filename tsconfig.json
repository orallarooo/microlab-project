{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "CommonJS",
    "target": "es6",
    "jsx": "react-jsx",
    "allowJs": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "app/*": [
        "./src/app/*"
      ],
      "pages/*": [
        "./src/pages/*"
      ],
      "widgets/*": [
        "./src/widgets/*"
      ],
      "features/*": [
        "./src/features/*"
      ],
      "entities/*": [
        "./src/entities/*"
      ],
      "shared/*": [
        "./src/shared/*"
      ]
    },
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "jest"
    ]
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}